{
  "name": "@subtextdev/subtext-embed",
  "version": "0.1.0",
  "description": "Host SDK for embedding the Subtext trace viewer — trace-scoped auth tokens via postMessage, React and vanilla entries.",
  "type": "module",
  "sideEffects": false,
  "main": "./build/src/index.js",
  "types": "./build/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "import": "./build/src/index.js"
    },
    "./react": {
      "types": "./build/src/react.d.ts",
      "import": "./build/src/react.js"
    }
  },
  "files": [
    "build/src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/*.test.ts",
    "test:build": "npm run build && node --test --test-force-exit build/tests/*.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fullstory",
    "subtext",
    "embed",
    "iframe",
    "react"
  ],
  "license": "MIT",
  "homepage": "https://github.com/fullstorydev/subtext-embed-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fullstorydev/subtext-embed-sdk.git"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
